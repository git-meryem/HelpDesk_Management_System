@using UserApp.ViewModels;
@model VerifyEmailViewModel;

@{
    ViewData["Title"] = "Verify Email";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["BodyClass"] = "hold-transition login-page";
}

<div class="login-box">

    <div class="login-logo">
        <a href="#"><b>HelpDesk</b> App</a>
    </div>

    <div class="card">
        <div class="card-body login-card-body">

            <p class="login-box-msg">Verify your email</p>

            <form asp-action="VerifyEmail" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- EMAIL -->
                <div class="input-group mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-envelope"></span>
                        </div>
                    </div>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>

                <div class="row">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-block">
                            Verify
                        </button>
                    </div>
                </div>

            </form>

            <p class="mt-3 mb-0 text-center">
                <a asp-controller="Account" asp-action="Login">
                    Back to Login
                </a>
            </p>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}