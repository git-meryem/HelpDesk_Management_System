@model UserApp.Models.Ticket

@{
    ViewData["Title"] = "Edit Ticket";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .card {
        border-radius: 14px;
        border: none;
    }

    .form-label {
        font-weight: 600;
        color: #333;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,.15);
        }

    .drop-zone {
        border: 2px dashed #0d6efd;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
        background: #fafbff;
    }

        .drop-zone:hover {
            background: #f1f6ff;
            border-color: #0b5ed7;
        }

    .preview-box {
        position: relative;
        display: inline-block;
    }

        .preview-box img {
            height: 90px;
            width: 90px;
            border-radius: 10px;
            object-fit: cover;
            box-shadow: 0 6px 15px rgba(0,0,0,0.08);
        }

        .preview-box button {
            position: absolute;
            top: -6px;
            right: -6px;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            font-size: 12px;
            padding: 0;
        }

    .page-title {
        font-weight: 700;
    }

    .subtitle {
        color: #6c757d;
        font-size: 13px;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 10px 20px;
    }

    .btn-outline-secondary {
        border-radius: 10px;
    }
    .existing-img-box {
    position: relative;
    display: inline-block;
}

.existing-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid #eee;
    transition: 0.2s;
}

.existing-img:hover {
    transform: scale(1.05);
}

.delete-btn {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    padding: 0;
    font-size: 12px;
}
</style>



<div class="container-fluid py-3">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="page-title">Edit Ticket</h3>
            <div class="subtitle">Update ticket information</div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>

    <div class="card shadow-sm">

        <div class="card-body p-4">

            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="Id" />

                <!-- TITLE -->
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <!-- DESCRIPTION -->
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <!-- STATUS -->
                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option>Open</option>
                        <option>In Progress</option>
                        <option>Closed</option>
                    </select>
                </div>

                <!-- CATEGORY + AGENT -->
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Category</label>
                        <select asp-for="CategoryId" class="form-select">
                            @foreach (var c in ViewBag.Categories)
                            {
                                <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">
                                    @c.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Agent</label>
                        <select asp-for="AssignedToId" class="form-select">
                            <option value="">Not Assigned</option>
                            @foreach (var a in ViewBag.Agents)
                            {
                                <option value="@a.Id" selected="@(Model.AssignedToId == a.Id)">
                                    @a.FullName
                                </option>
                            }
                        </select>
                    </div>

                </div>

                <!-- DROPZONE -->
                <div class="mb-3">

                    <label class="form-label">Add new screenshots</label>

                    <div id="dropZone" class="drop-zone">
                        📂 Drag & Drop images or click to upload
                        <input type="file" id="fileInput" name="files" multiple hidden />
                    </div>

                    <div id="previewContainer" class="d-flex flex-wrap gap-2 mt-3"></div>

                </div>

                <!-- EXISTING IMAGES -->
                <div class="mb-3">

                    <label class="form-label">Existing attachments</label>

                    <div class="d-flex flex-wrap gap-2">

                        @foreach (var img in Model.Attachments ?? new List<UserApp.Models.Attachment>())
                        {
                            <div class="position-relative existing-img-box">

                                <img src="@Url.Content(img.FilePath)"
                                     class="existing-img" />

                                <button type="button"
                                        class="btn btn-danger btn-sm delete-btn"
                                        onclick="deleteAttachment(@img.Id)">
                                    ×
                                </button>

                            </div>
                        }

                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>

                </div>

            </form>

        </div>

    </div>
</div>

<script>

    let filesList = [];

    const dropZone = document.getElementById("dropZone");
    const fileInput = document.getElementById("fileInput");
    const previewContainer = document.getElementById("previewContainer");

    dropZone.addEventListener("click", () => fileInput.click());

    fileInput.addEventListener("change", (e) => handleFiles(e.target.files));

    dropZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.style.background = "#eef4ff";
    });

    dropZone.addEventListener("dragleave", () => {
        dropZone.style.background = "#fafbff";
    });

    dropZone.addEventListener("drop", (e) => {
        e.preventDefault();
        handleFiles(e.dataTransfer.files);
    });

    function handleFiles(files) {

        for (let file of files) {

            if (!file.type.startsWith("image/")) continue;

            filesList.push(file);

            const reader = new FileReader();

            reader.onload = function (e) {

                const div = document.createElement("div");
                div.className = "preview-box";

                div.innerHTML = `
                    <img src="${e.target.result}">
                    <button type="button" class="btn btn-danger btn-sm">×</button>
                `;

                div.querySelector("button").onclick = () => {
                    previewContainer.removeChild(div);
                    filesList = filesList.filter(f => f !== file);
                };

                previewContainer.appendChild(div);
            };

            reader.readAsDataURL(file);
        }
    }

    document.querySelector("form").addEventListener("submit", function () {
        const dt = new DataTransfer();
        filesList.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
    });

</script>
<script>

function deleteAttachment(id) {

    // if (!confirm("Are you sure you want to delete this image?")) {
    //     return;
    // }

    fetch('/Tickets/DeleteAttachment/' + id, {
        method: 'POST'
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            location.reload(); 
        } else {
            alert("Error deleting image");
        }
    });
}

</script>