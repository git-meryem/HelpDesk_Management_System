@model List<UserApp.Models.Ticket>

@{
    ViewData["Title"] = "Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="container-fluid">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
            <div>
                <h3 class="fw-bold mb-0">Tickets</h3>
                <small class="text-muted">Manage support tickets</small>
            </div>

            @if (!User.IsInRole("Agent"))
            {
                <a asp-action="Create" class="btn btn-primary rounded-pill px-3">
                    + New Ticket
                </a>
            }
        </div>

        <!-- CARD -->
        <div class="card shadow-sm border-0">

            <!-- SEARCH -->
            <div class="card-header bg-white">
                <input type="text"
                       id="searchInput"
                       class="form-control form-control-sm w-25"
                       placeholder="Search ticket..." />
            </div>

            <!-- TABLE -->
            <div class="card-body p-0">
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0" id="ticketsTable">

                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Title</th>
                                <th>Status</th>
                                <th>Category</th>
                                <th>Agent</th>
                                <th>User</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.Id</td>
                                    <td>@item.Title</td>

                                    <td>
                                        @if (item.Status == "Open")
                                        {
                                            <span class="badge bg-success">Open</span>
                                        }
                                        else if (item.Status == "In Progress")
                                        {
                                            <span class="badge bg-warning text-dark">In Progress</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Closed</span>
                                        }
                                    </td>

                                    <td>@item.Category?.Name</td>
                                    <td>@(item.AssignedTo?.FullName ?? "Not Assigned")</td>
                                    <td>@item.User?.FullName</td>

                                    <td class="text-end">

                                        <a asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-warning">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        @if (!User.IsInRole("Agent"))
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger deleteBtn"
                                                    data-toggle="modal"
                                                    data-target="#deleteModal"
                                                    data-id="@item.Id"
                                                    data-title="@item.Title">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }

                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            </div>

        </div>

    </div>
</section>

 <div class="modal fade" id="deleteModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <!-- HEADER -->
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Ticket</h5>

                    <button type="button"
                            class="close text-white"
                            data-dismiss="modal"
                            aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <!-- BODY -->
                <div class="modal-body">
                    <p class="mb-0">
                        Are you sure you want to delete
                        <strong id="deleteName"></strong> ?
                    </p>

                    <input type="hidden" id="deleteId" name="id" />
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-danger">
                        Delete
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>
<script src="~/plugins/jquery/jquery.min.js"></script>

<script>
    $(document).ready(function () {

      
        $("#searchInput").on("keyup", function () {
            let value = $(this).val().toLowerCase();

            $("#ticketsTable tbody tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            });
        });

        

    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".deleteBtn").forEach(btn => {
            btn.addEventListener("click", function () {

                document.getElementById("deleteId").value = this.dataset.id;
                document.getElementById("deleteName").innerText = this.dataset.title;

            });
        });

    });
</script>

@section Scripts {
    <script>
        $(document).ready(function () {

            var success = '@(TempData["Success"] ?? "")';
            var error = '@(TempData["Error"] ?? "")';

            if (success.trim() !== "") {
                showSuccess(success);
            }

            if (error.trim() !== "") {
                showError(error);
            }

        });
    </script>
}
