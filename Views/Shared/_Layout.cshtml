@using UserApp.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<Users> userManager

@{
    var currentUser = await userManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <!-- AdminLTE -->
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css" />

    <!-- TOASTR -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

</head>

<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        <!-- NAVBAR -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav ml-auto">
                <partial name="_LoginPartial" />
            </ul>
        </nav>

        <!-- SIDEBAR -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">

            <div class="sidebar">

                <!-- BRAND -->
                <div class="text-center py-3 border-bottom mb-2">
                    <h5 class="text-white mb-0">
                        <i class="fas fa-headset text-primary"></i> HelpDesk
                    </h5>
                    <small class="text-muted">Support System</small>
                </div>

                <!-- USER -->
                <div class="px-3 pb-3 mb-3 border-bottom border-secondary d-flex align-items-center">

                    <img src="@(currentUser?.ProfileImage != null
                                                             ? currentUser.ProfileImage
                                                             : "https://ui-avatars.com/api/?name=" + currentUser?.FullName + "&background=0d6efd&color=fff")"
                         class="img-circle elevation-2"
                         style="width:40px; height:40px; object-fit:cover;" />

                    <div class="ml-2 text-white">
                        <div class="text-truncate" style="max-width:140px;">
                            @currentUser?.FullName
                        </div>
                        <small class="text-success">Online</small>
                    </div>

                </div>

                <!-- MENU -->
                <nav>
                    <ul class="nav nav-pills nav-sidebar flex-column px-2">

                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-chart-line"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Tickets" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-ticket-alt"></i>
                                <p>Tickets</p>
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Categories" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-tags"></i>
                                    <p>Categories</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a asp-controller="Users" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-users"></i>
                                    <p>Users</p>
                                </a>
                            </li>
                        }

                        <li class="nav-header">Account</li>

                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Profile" class="nav-link">
                                <i class="nav-icon fas fa-user"></i>
                                <p>Profile</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="nav-link text-danger w-100 text-left border-0 bg-transparent">
                                    <i class="nav-icon fas fa-sign-out-alt"></i>
                                    <p>Logout</p>
                                </button>
                            </form>
                        </li>

                    </ul>
                </nav>

            </div>
        </aside>

        <!-- CONTENT -->
        <div class="content-wrapper">
            <section class="content pt-3">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- FOOTER -->
        <footer class="main-footer text-center">
            <strong>HelpDesk System © 2026</strong>
        </footer>

    </div>

    <!-- JS -->
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.min.js"></script>

    <!-- TOASTR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- TOASTR CONFIG -->
    <script>
        toastr.options = {
        "closeButton": true,
        "progressBar": true,
        "positionClass": "toast-top-right",
        "timeOut": "3000"
        };

        function showSuccess(message) {
        toastr.success(message);
        }

        function showError(message) {
        toastr.error(message);
        }

        function showInfo(message) {
        toastr.info(message);
        }

        function showWarning(message) {
        toastr.warning(message);
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>